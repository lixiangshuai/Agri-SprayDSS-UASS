{
  "project": "Agricultural Spray Decision Support System for Unmanned Aerial Spraying Systems (Agri-SprayDSS-UASS)",
  "version": "1.0.0",
  "runtime_strategy": {
    "training_in_platform": false,
    "test_set_sampling_in_platform": false,
    "shap_scope": "single current user input",
    "shap_value_source": "xgboost Booster.predict(pred_contribs=True)",
    "shap_color_policy": "default SHAP force plot colors",
    "shap_export": "Current-input SHAP force plots can be exported as 300 dpi PNG files.",
    "hidden_explanation_features": ["distance"],
    "temperature_humidity_guidance": "Raw SHAP values are not reversed. Temperature and relative humidity may receive opposite operating guidance because higher temperature promotes droplet evaporation, while higher relative humidity suppresses evaporation.",
    "hidden_feature_policy": "Distance is used in prediction and SHAP computation but hidden from force plots, feature tables, and recommendations."
  },
  "models": {
    "fine": {
      "label_en": "Fine droplet size",
      "label_zh": "细雾滴粒径",
      "file": "fine_droplet_xgb.ubj",
      "type": "xgboost.XGBRegressor",
      "wind_speed_reference_m_s": 2.2,
      "operating_altitude_reference_m": 2.92,
      "operating_speed_reference_m_s": 4.65,
      "temperature_empirical_range": [10, 40],
      "temperature_unit": "℃"
    },
    "medium": {
      "label_en": "Medium droplet size",
      "label_zh": "中等雾滴粒径",
      "file": "medium_droplet_xgb.ubj",
      "type": "xgboost.XGBRegressor",
      "wind_speed_reference_m_s": 3.78,
      "operating_altitude_reference_m": 3.34,
      "operating_speed_reference_m_s": 5.09,
      "temperature_empirical_range": [12, 23],
      "temperature_unit": "℃"
    }
  },
  "single_threshold_drift_reduction_rules": {
    "fine": {
      "operating_altitude": { "operator": ">", "threshold": 2.92, "unit": "m" },
      "operating_speed": { "operator": ">", "threshold": 4.65, "unit": "m/s" },
      "wind_speed": { "operator": ">", "threshold": 2.20, "unit": "m/s" },
      "wind_deviation": { "operator": "<", "threshold": 20.59, "unit": "°" },
      "temperature": { "operator": ">", "threshold": 21.49, "unit": "℃" },
      "relative_humidity": { "operator": "<", "threshold": 55.51, "unit": "%" }
    },
    "medium": {
      "operating_altitude": { "operator": ">", "threshold": 3.34, "unit": "m" },
      "operating_speed": { "operator": ">", "threshold": 5.09, "unit": "m/s" },
      "wind_speed": { "operator": ">", "threshold": 3.78, "unit": "m/s" },
      "wind_deviation": { "operator": "<", "threshold": 20.46, "unit": "°" },
      "temperature": { "operator": ">", "threshold": 18.68, "unit": "℃" },
      "relative_humidity": { "operator": "<", "threshold": 54.05, "unit": "%" }
    }
  },
  "model_feature_order": [
    "Operating altitude (m)",
    "Operating speed (m/s)",
    "Wind speed (m/s)",
    "Wind deviation (°)",
    "Temperature (℃)",
    "Relative humidity (%)",
    "Distance"
  ],
  "platform_inputs": [
    {
      "key": "wind_speed",
      "label_en": "Wind speed",
      "label_zh": "风速",
      "unit": "m/s",
      "recommended_range": [0, 7],
      "notes": "Fine droplet threshold: 2.20 m/s; medium droplet threshold: 3.78 m/s."
    },
    {
      "key": "wind_deviation",
      "label_en": "Wind deviation",
      "label_zh": "风向偏角",
      "unit": "°",
      "recommended_range": [0, 90],
      "notes": "Effective crosswind angle converted to 0-90°. Fine threshold: not lower than 20.59°; medium threshold: not lower than 20.46°."
    },
    {
      "key": "temperature",
      "label_en": "Temperature",
      "label_zh": "温度",
      "unit": "℃",
      "recommended_range": [10, 40],
      "notes": "Fine threshold: 21.49℃; medium threshold: 18.68℃. Medium droplet model gives an extrapolation warning outside 12-23℃."
    },
    {
      "key": "relative_humidity",
      "label_en": "Relative humidity",
      "label_zh": "相对湿度",
      "unit": "%",
      "recommended_range": [20, 80],
      "notes": "Fine threshold: higher than 55.51%; medium threshold: higher than 54.05%."
    },
    {
      "key": "operating_altitude",
      "label_en": "Operating altitude",
      "label_zh": "作业高度",
      "unit": "m",
      "recommended_range": [2, 6],
      "notes": "Fine droplet: prioritize <2.92 m; medium droplet: prioritize <3.34 m."
    },
    {
      "key": "operating_speed",
      "label_en": "Operating speed",
      "label_zh": "作业速度",
      "unit": "m/s",
      "recommended_range": [3, 8],
      "notes": "Fine droplet threshold about 4.65 m/s; medium droplet threshold about 5.09 m/s."
    },
    {
      "key": "droplet_size",
      "label_en": "Droplet size",
      "label_zh": "雾滴粒径类型",
      "unit": "model selector",
      "allowed_values": ["fine", "medium"],
      "notes": "Droplet size is not a numeric feature in the fitted models; it selects which .ubj model to run."
    },
    {
      "key": "distance",
      "label_en": "Downwind distance",
      "label_zh": "下风向距离",
      "unit": "m",
      "recommended_range": [1, 100],
      "default": 1,
      "notes": "The interface warns above 50 m because 1-50 m is the recommended planning range."
    }
  ]
}
